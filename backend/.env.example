PORT=5000
MONGODB_URI=mongodb://localhost:27017/lms

# ⚠️ SECURITY WARNING: Generate strong random secrets for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER use these default values in production!
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX_STRING_IN_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_THIS_TO_DIFFERENT_RANDOM_64_CHAR_HEX_STRING_IN_PRODUCTION

NODE_ENV=development

# CORS Configuration (comma-separated origins for production)
# Example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Redis Cache (optional - leave empty to disable caching)
# Example: REDIS_URL=redis://localhost:6379
REDIS_URL=

# CDN Configuration (optional - for serving static assets)
CDN_URL=

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@company.com
